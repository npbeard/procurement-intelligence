# Copy this file to .env and fill in your values. Never commit .env.

# Databricks workspace
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=dapi...
# SQL Warehouse HTTP path — find it in: SQL → Warehouses → <your warehouse> → Connection details
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>

# Bronze layer root — where raw TED XMLs land.
# Local dev:    data/bronze/ted
# Databricks:   /Volumes/<catalog>/<schema>/<volume>/bronze/ted
BRONZE_PATH=data/bronze/ted
